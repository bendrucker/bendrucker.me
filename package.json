{
  "name": "bendrucker.me",
  "type": "module",
  "version": "1.0.0",
  "workspaces": [
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "dev": "spotlight run astro dev",
    "build": "npm run build:packages && npm run types:generate && astro check && astro build",
    "build:packages": "npm run build --workspace=packages/logger -- --force && npm run build --workspace=packages/github -- --force",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lighthouse": "lhci autorun",
    "types:generate": "wrangler types && prettier --write worker-configuration.d.ts",
    "test": "vitest run",
    "fetch-activity": "tsx scripts/fetch-github-activity.ts"
  },
  "dependencies": {
    "@astrojs/alpinejs": "0.5.0",
    "@astrojs/cloudflare": "13.5.1",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.1",
    "@astrojs/vue": "6.0.1",
    "@cf-wasm/resvg": "^0.3.4",
    "@cf-wasm/satori": "^0.3.6",
    "@date-fns/tz": "^1.4.1",
    "@sentry/cloudflare": "^10.51.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^25.6.0",
    "alpinejs": "^3.15.12",
    "astro": "6.3.2",
    "date-fns": "^4.1.0",
    "kysely": "^0.29.0",
    "lodash.kebabcase": "^4.1.1",
    "reka-ui": "^2.9.2",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@lhci/cli": "^0.15.1",
    "@sentry/astro": "^10.52.0",
    "@shikijs/transformers": "^4.0.2",
    "@spotlightjs/spotlight": "^4.11.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/lodash.kebabcase": "^4.1.9",
    "@typescript-eslint/parser": "^8.59.3",
    "better-sqlite3": "^12.9.0",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "linguist-languages": "^9.3.2",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  },
  "overrides": {
    "zod": "4.3.6",
    "qs": "6.15.0",
    "lodash": "4.17.23",
    "tmp": "0.2.5"
  }
}
